# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.playwright-mcp/
*.so

# uv lock — keep committed for reproducibility
# uv.lock  ← intentionally NOT ignored

# MinionsOS runtime state (generated at runtime, not source)
# NOTE: minions/state/ itself contains source modules (store.py, state_store.py,
# port_allocator.py, __init__.py). Only the runtime artifacts are ignored.
minions/state/logs/
minions/state/projects.json
minions/state/*.db
minions/state/*.db-shm
minions/state/*.db-wal
minions/state/*.pid
minions/state/*.lock
minions/state/*.host
# One-off rotation backups produced by Gru's projects.json cleanup tools.
# Pattern: projects.json.bak-cleanup-YYYYMMDD-HHMMSS. These are local-only
# and never meant to land in the repo.
minions/state/*.bak-*
# Timestamped backups produced by `mos project prune` before it mutates
# projects.json. Pattern: projects.json.prune-bak-YYYYMMDD-HHMMSS. Local-only.
minions/state/*.prune-bak-*
# Gru crash watchdog counter — runtime liveness state, regenerated on demand.
minions/state/crash_counter.json
# Codex Gru role contract file: regenerated from minions/roles/SYSTEM.md +
# minions/roles/gru/SYSTEM.md on every ./gru (codex) launch. Runtime artifact.
minions/state/codex-gru.AGENTS.md

# Config files with secrets/local paths — only .example files are committed
minions/config/*.yaml
!minions/config/*.yaml.example

# Per-project runtime directories (created by Gru at runtime)
# Matches both old layout (beside MinionsOS) and new layout (MinionsOS/projects/)
project_*/eacn3_data/
project_*/artifacts/
project_*/artifacts/ethics/
project_*/memory/
project_*/logs/
project_*/branches/
project_*/state/
project_*/events/
project_*/parent_repo.git/
projects/

# Generated test-suite overview page (regenerated from pytest collection)
tests/_overview.html

# Node
node_modules/
EACN3/plugin/dist/
EACN3/plugin/node_modules/

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo
.claude/*.local.md
**/.claude/*.local.md
.claude/worktrees/

# EACN3 legacy patterns (from original .gitignore)
eacn/network/config.toml
eacn3.db
eacn3.db-shm
eacn3.db-wal
data/
answer/
.git.backup-v1/

# minions-viz (Observatory frontend) — commit src + dist, not installed deps
minions-viz/node_modules/
minions-viz/.vite/
minions-viz/preview/
minions-viz-v2/.vite/

# Stray dev log
output.log

# Local cleanup holding area (reference materials, not MinionsOS source)
other/

# Dev workspace — kept locally, not delivered to GitHub
# (docs/reel-l0-memory.md is delivery — describes the live L0 Reel layer)
dev-log/
outline/
experiments/
# Dev eval reports (generated by skill-evaluator runs)
minions/roles/common/SKILL_EVAL.md
minions/roles/common/SKILL_BEHAVIORAL_EVAL.md
minions/roles/common/_evals/
minions/roles/common/_behavioral_evals/
# Root design-mockup screenshots (not referenced by README)
/viz-atlas.png
/viz-picker-redesigned.png
/viz-project-picker.png
/viz-redesign-overview.png
/viz-tasks-board.png

.mcp.json
.codex/config.toml

# Background visual-extras installer artifacts (install.sh phase B)
.install_visual.log
.install_visual.pid

# Incremental install freshness stamps (install.sh)
.install_stamps/

# Phantom project dirs created by old launcher bug (pre-v15.53)
# Safe to delete after upgrade — real project data lives in projects/ or parent dir
/project_*/

# Rebuild (v23) local-only references — kept on disk, not delivered:
#   - the external reference repo our ideas are *based on* (its name must not
#     scatter across our tree — naming discipline D5); it's a local reference.
#   - regenerable LaTeX build intermediates from the Book→Paper validation runs.
#   - pre-rebuild scratch docs with now-stale paths / unrelated slide mockups.
docs/Reconstruction/Agent-Native-Research-Artifact-main/
docs/Reconstruction/book2paper-validation/**/*.aux
docs/Reconstruction/book2paper-validation/**/*.log
docs/Reconstruction/book2paper-validation/**/*.fls
docs/Reconstruction/book2paper-validation/**/*.fdb_latexmk
docs/Reconstruction/book2paper-validation/**/*.out
docs/Reconstruction/book2paper-validation/**/*.bbl
docs/Reconstruction/book2paper-validation/**/*.blg
# Redundant PDF copies — main.pdf is the canonical compiled artifact each
# round (matches RESULTS.md page counts); paper.pdf is a duplicate/stale copy.
docs/Reconstruction/book2paper-validation/**/paper.pdf
docs/Skill_Summary.md
docs/report/
