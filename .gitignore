# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.playwright-mcp/
*.so

# uv lock — keep committed for reproducibility
# uv.lock  ← intentionally NOT ignored

# MinionsOS runtime state (generated at runtime, not source)
# NOTE: minions/state/ itself contains source modules (store.py, state_store.py,
# port_allocator.py, __init__.py). Only the runtime artifacts are ignored.
minions/state/logs/
minions/state/projects.json
minions/state/*.db
minions/state/*.db-shm
minions/state/*.db-wal
minions/state/*.pid
minions/state/*.lock
minions/state/*.host
# Codex Gru role contract file: regenerated from minions/roles/SYSTEM.md +
# minions/roles/gru/SYSTEM.md on every ./gru (codex) launch. Runtime artifact.
minions/state/codex-gru.AGENTS.md

# Config files with secrets/local paths — only .example files are committed
minions/config/*.yaml
!minions/config/*.yaml.example

# Per-project runtime directories (created by Gru at runtime)
project_*/eacn3_data/
project_*/artifacts/
project_*/artifacts/ethics/
project_*/memory/
project_*/logs/
project_*/branches/
project_*/state/
project_*/events/
project_*/parent_repo.git/

# Generated test-suite overview page (regenerated from pytest collection)
tests/_overview.html

# Node
node_modules/
EACN3/plugin/dist/
EACN3/plugin/node_modules/

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo
.claude/*.local.md
**/.claude/*.local.md
.claude/worktrees/

# EACN3 legacy patterns (from original .gitignore)
eacn/network/config.toml
eacn3.db
eacn3.db-shm
eacn3.db-wal
data/
answer/
.git.backup-v1/

# minions-viz (Observatory frontend) — commit src + dist, not installed deps
minions-viz/node_modules/
minions-viz/.vite/
minions-viz/preview/
minions-viz-v2/.vite/

# Stray dev log
output.log

# Local cleanup holding area (reference materials, not MinionsOS source)
other/

# Dev workspace — kept locally, not delivered to GitHub
# (docs/reel-l0-memory.md is delivery — describes the live L0 Reel layer)
dev-log/
outline/
experiments/
# Dev eval reports (generated by skill-evaluator runs)
minions/roles/common/SKILL_EVAL.md
minions/roles/common/SKILL_BEHAVIORAL_EVAL.md
minions/roles/common/_evals/
minions/roles/common/_behavioral_evals/
# Root design-mockup screenshots (not referenced by README)
/viz-atlas.png
/viz-picker-redesigned.png
/viz-project-picker.png
/viz-redesign-overview.png
/viz-tasks-board.png

# codegraph repo-scope index — built by install.sh's warmup step.
# Project-scope indexes live under project_*/branches/coder/.codegraph/ and
# are covered by the existing project_* ignore.
.codegraph/
