{
  "name": "eacn-viz",
  "version": "0.1.0",
  "description": "Real-time visualization dashboard for EACN multi-agent network",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build && tsc --project tsconfig.server.json",
    "build:static": "GITHUB_PAGES=true vite build",
    "start": "npx tsx src/server/index.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dagre": "^0.7.52",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
