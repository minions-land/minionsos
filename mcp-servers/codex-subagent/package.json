{
  "name": "@minionsos/codex-subagent",
  "version": "1.1.0",
  "description": "MCP server exposing Codex GPT-5.5 as a sub-agent to Claude Code for high-intensity coding tasks",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "codex-subagent": "scripts/cli.cjs"
  },
  "files": [
    "dist/",
    "scripts/",
    "skills/",
    ".mcp.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "codex",
    "gpt-5.5",
    "openai",
    "agent",
    "delegation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataLab-atom/codex-subagent.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
