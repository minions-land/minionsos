{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/server",
    "rootDir": "src",
    "paths": { "@shared/*": ["./src/shared/*"] }
  },
  "include": ["src/server", "src/shared"]
}
