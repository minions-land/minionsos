{
  "name": "minions-viz",
  "version": "0.3.0",
  "description": "MinionsOS Observatory — WebXR/VR mission-control dashboard",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "node --require ./node_modules/tsx/dist/preflight.cjs --import file://$PWD/node_modules/tsx/dist/loader.mjs src/server/index.ts",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "9.114.3",
    "@react-three/fiber": "8.17.10",
    "@react-three/xr": "5.7.1",
    "cors": "2.8.5",
    "express": "4.21.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "three": "0.169.0",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@types/three": "0.169.0",
    "@types/ws": "8.5.12",
    "@vitejs/plugin-react": "4.3.2",
    "concurrently": "9.0.1",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "vite": "5.4.9"
  }
}
