#!/usr/bin/env bash
# minions/bin/gru — MinionsOS V4 launcher.
# Symlinked as ./gru, ./minionsos, ./mos at the repo root.
#
# Usage:
#   ./gru                          Launch Gru agent-host session (interactive)
#   ./gru --daemon                 Launch Gru in background (nohup)
#   ./gru attach                   Show how to follow Gru logs
#   ./gru --resume                 Pass --resume through to Claude host
#   ./gru status|logs|doctor|noter|...   Dispatch to `mos` CLI
set -euo pipefail

# ── Resolve repo root from this script's location ────────────────────────────
# Resolve symlinks so ./mos, ./gru, ./minionsos all locate the real bin dir.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" = /* ]]; then
        SOURCE="$TARGET"
    else
        SOURCE="$(cd "$(dirname "$SOURCE")" && pwd)/$TARGET"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
if [ -n "${VIRTUAL_ENV:-}" ] && [ "$VIRTUAL_ENV" != "$ROOT/.venv" ]; then
    unset VIRTUAL_ENV
fi

# ── ANSI colours ──────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'
BOLD='\033[1m'; RESET='\033[0m'

info()  { echo -e "${CYAN}[gru]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[gru]${RESET} $*"; }
die()   { echo -e "${RED}[gru]${RESET} $*" >&2; exit 1; }

# ── Subcommand whitelist ──────────────────────────────────────────────────────
SUBCOMMANDS="status|logs|doctor|config|noter|project|role|wipe|viz|--help|-h"

is_subcommand() {
    local arg="${1:-}"
    [[ "$arg" =~ ^(status|logs|doctor|config|noter|project|role|wipe|viz|--help|-h)$ ]]
}

# ── State dir ─────────────────────────────────────────────────────────────────
STATE_DIR="$ROOT/minions/state"
mkdir -p "$STATE_DIR"
PID_FILE="$STATE_DIR/gru.pid"
MONITOR_PID_FILE="$STATE_DIR/gru-monitor.pid"
LOG_FILE="$STATE_DIR/logs/gru.log"
MONITOR_LOG_FILE="$STATE_DIR/logs/gru-monitor.log"
mkdir -p "$STATE_DIR/logs"

# ── Dependency checks ─────────────────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
    die "uv not found. Run ./install.sh first."
fi

if [ -z "${MINIONS_AGENT_HOST:-}" ]; then
    MINIONS_AGENT_HOST="$(uv run --project "$ROOT" python -c 'from minions.config import load_gru_config; print(load_gru_config().effective_agent_host())' 2>/dev/null || echo claude)"
fi
MINIONS_AGENT_HOST="$(printf '%s' "$MINIONS_AGENT_HOST" | tr '[:upper:]' '[:lower:]')"
export MINIONS_AGENT_HOST

if [ "$MINIONS_AGENT_HOST" = "codex" ]; then
    if ! command -v codex &>/dev/null; then
        warn "codex CLI not found on PATH; Codex Gru launch will fail unless codex is available."
    fi
else
    MINIONS_AGENT_HOST="claude"
    if ! command -v claude &>/dev/null && ! uv run --project "$ROOT" claude --version &>/dev/null 2>&1; then
        warn "claude CLI not found on PATH; will attempt via 'uv run claude'."
    fi
fi

# ── Parse args ────────────────────────────────────────────────────────────────
DAEMON=0
RESUME_ARGS=()
PASSTHROUGH_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --daemon)
            DAEMON=1
            shift
            ;;
        attach)
            info "Gru daemon log: ${CYAN}$LOG_FILE${RESET}"
            info "To follow:  tail -f $LOG_FILE"
            if [ -f "$PID_FILE" ]; then
                PID=$(cat "$PID_FILE")
                if kill -0 "$PID" 2>/dev/null; then
                    info "Gru daemon is running (PID $PID)"
                else
                    warn "PID file exists but process $PID is not running"
                fi
            else
                warn "No PID file found — Gru daemon may not be running"
            fi
            exit 0
            ;;
        --resume)
            RESUME_ARGS+=("--resume")
            shift
            ;;
        *)
            PASSTHROUGH_ARGS+=("$1")
            shift
            ;;
    esac
done

# ── Dispatch to CLI subcommands ───────────────────────────────────────────────
if [ ${#PASSTHROUGH_ARGS[@]} -gt 0 ] && is_subcommand "${PASSTHROUGH_ARGS[0]}"; then
    exec uv run --project "$ROOT" mos "${PASSTHROUGH_ARGS[@]}"
fi

# ── Launch Gru agent session ──────────────────────────────────────────────────
SYSTEM_PROMPT="$ROOT/minions/roles/gru/SYSTEM.md"
MCP_CONFIG="$ROOT/.mcp.json"

if [ ! -f "$SYSTEM_PROMPT" ]; then
    warn "Gru SYSTEM.md not found at $SYSTEM_PROMPT — launching without system prompt override"
    SYSTEM_PROMPT_ARGS=()
else
    SYSTEM_PROMPT_ARGS=(--append-system-prompt "@$SYSTEM_PROMPT")
fi

if [ ! -f "$MCP_CONFIG" ]; then
    warn ".mcp.json not found at $MCP_CONFIG — launching without MCP config"
    MCP_ARGS=()
else
    MCP_ARGS=(--mcp-config "$MCP_CONFIG")
fi

# Author's required Gru invocation defaults. Override with env:
#   MINIONS_AGENT_HOST=claude|codex  (default: gru.yaml, then claude)
#   GRU_MODEL=...        (Claude default: claude-opus-4-7; Codex default: CLI profile)
#   GRU_EFFORT=...       (default: max)
#   GRU_SANDBOX=0        (unset IS_SANDBOX; default: 1)
#   GRU_SKIP_PERMS=0     (omit --dangerously-skip-permissions; default: 1)
#   CODEX_BYPASS=0       (disable Codex bypass; default: 1)
#   CODEX_REASONING_EFFORT=... (default: xhigh)
#   CODEX_SANDBOX=...    (used when CODEX_BYPASS=0; default: workspace-write)
#   CODEX_APPROVAL_POLICY=... (used when CODEX_BYPASS=0; default: on-request)
#   GRU_VIZ=0            (disable Observatory auto-start; default: 1)
#   GRU_VIZ_OPEN=0       (do not open browser on interactive launch; default: 1)
#   MINIONS_VIZ_PORT=N   (override default Observatory port 7891)
#   MINIONS_GRU_MONITOR=0 (disable Python monitor/WakeupScheduler sidecar)
: "${GRU_EFFORT:=max}"
: "${GRU_SANDBOX:=1}"
: "${GRU_SKIP_PERMS:=1}"

if [ "$GRU_SANDBOX" = "1" ]; then
    export IS_SANDBOX=1
fi

if [ "$MINIONS_AGENT_HOST" = "codex" ]; then
    : "${CODEX_BYPASS:=1}"
    : "${CODEX_REASONING_EFFORT:=xhigh}"
    CODEX_FLAGS=(--cd "$ROOT" -c "model_reasoning_effort=\"$CODEX_REASONING_EFFORT\"")
    if [ "$CODEX_BYPASS" = "1" ]; then
        CODEX_FLAGS+=(--dangerously-bypass-approvals-and-sandbox)
    else
        CODEX_FLAGS+=(
            --sandbox "${CODEX_SANDBOX:-workspace-write}"
            --ask-for-approval "${CODEX_APPROVAL_POLICY:-on-request}"
        )
    fi
    if [ -n "${GRU_MODEL:-}" ]; then
        CODEX_FLAGS+=(--model "$GRU_MODEL")
    fi
    if [ ${#RESUME_ARGS[@]} -gt 0 ]; then
        warn "--resume is Claude-specific in this launcher; ignoring it for Codex."
    fi
    CODEX_PROMPT="You are Gru, the MinionsOS human-facing supervisor. Before acting, read and follow $SYSTEM_PROMPT. Start or verify the Gru monitor with gru_start_monitor, then poll Gru inboxes and help the author through MinionsOS MCP tools. Use project-scoped adapters for EACN communication."
    if [ ${#PASSTHROUGH_ARGS[@]} -gt 0 ]; then
        CODEX_PROMPT="$CODEX_PROMPT

Initial user request: ${PASSTHROUGH_ARGS[*]}"
    fi
    AGENT_CMD=(
        codex
        "${CODEX_FLAGS[@]}"
        "$CODEX_PROMPT"
    )
else
    : "${GRU_MODEL:=claude-opus-4-7}"
    GRU_FLAGS=(--model "$GRU_MODEL" --effort "$GRU_EFFORT")
    if [ "$GRU_SKIP_PERMS" = "1" ]; then
        GRU_FLAGS+=(--dangerously-skip-permissions)
    fi
    AGENT_CMD=(
        uv run --project "$ROOT"
        claude
        "${GRU_FLAGS[@]}"
        "${SYSTEM_PROMPT_ARGS[@]+"${SYSTEM_PROMPT_ARGS[@]}"}"
        "${MCP_ARGS[@]+"${MCP_ARGS[@]}"}"
        "${RESUME_ARGS[@]+"${RESUME_ARGS[@]}"}"
        "${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}"
    )
fi

# ── Auto-start Gru monitor + WakeupScheduler sidecar ────────────────────────
ensure_gru_monitor() {
    if [ "${MINIONS_GRU_MONITOR:-1}" = "0" ]; then
        return 0
    fi
    if [ -f "$MONITOR_PID_FILE" ]; then
        local existing_pid
        existing_pid="$(cat "$MONITOR_PID_FILE" 2>/dev/null || echo "")"
        if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
            return 0
        fi
        rm -f "$MONITOR_PID_FILE"
    fi

    info "Starting Gru monitor/WakeupScheduler sidecar..."
    if command -v setsid >/dev/null 2>&1; then
        nohup setsid uv run --project "$ROOT" python -m minions.gru.loop \
            >> "$MONITOR_LOG_FILE" 2>&1 &
    elif command -v python3 >/dev/null 2>&1; then
        nohup python3 -c 'import os,sys; os.setsid(); os.execvp(sys.argv[1], sys.argv[1:])' \
            uv run --project "$ROOT" python -m minions.gru.loop \
            >> "$MONITOR_LOG_FILE" 2>&1 &
    else
        nohup uv run --project "$ROOT" python -m minions.gru.loop \
            >> "$MONITOR_LOG_FILE" 2>&1 &
    fi
    echo "$!" > "$MONITOR_PID_FILE"
    info "Gru monitor log: $MONITOR_LOG_FILE"
}

ensure_gru_monitor

# ── Auto-start MinionsOS Observatory (viz, machine singleton) ────────────────
if [ "${GRU_VIZ:-1}" != "0" ] && [ -x "$ROOT/minions/bin/viz" ]; then
    if "$ROOT/minions/bin/viz" ensure >/dev/null 2>&1; then
        VIZ_URL="$(cat "$HOME/.minionsos/viz.url" 2>/dev/null || echo "http://127.0.0.1:${MINIONS_VIZ_PORT:-7891}")"
        info "MinionsOS Observatory: $VIZ_URL"
        if [ "$DAEMON" -eq 0 ] && [ "${GRU_VIZ_OPEN:-1}" != "0" ] && [ -t 0 ]; then
            ("$ROOT/minions/bin/viz" open >/dev/null 2>&1 &) || true
        fi
    else
        warn "Observatory failed to start (non-fatal). Try:  ./viz status ;  ./viz logs"
    fi
fi

if [ "$DAEMON" -eq 1 ]; then
    # Idempotency: if a live daemon already exists, do nothing.
    if [ -f "$PID_FILE" ]; then
        EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || echo "")"
        if [ -n "$EXISTING_PID" ] && kill -0 "$EXISTING_PID" 2>/dev/null; then
            info "Gru daemon already running (PID $EXISTING_PID). Nothing to do."
            info "Attach with:  $0 attach   Stop with:  kill $EXISTING_PID"
            exit 0
        fi
    fi
    info "Starting Gru in daemon mode..."
    info "Log: $LOG_FILE"
    # Detach into a new process group so logs/signals are isolated.
    # macOS lacks setsid(1); fall back to a python os.setsid() shim.
    if command -v setsid >/dev/null 2>&1; then
        nohup setsid "${AGENT_CMD[@]}" >> "$LOG_FILE" 2>&1 &
    elif command -v python3 >/dev/null 2>&1; then
        nohup python3 -c 'import os,sys; os.setsid(); os.execvp(sys.argv[1], sys.argv[1:])' \
            "${AGENT_CMD[@]}" >> "$LOG_FILE" 2>&1 &
    else
        nohup "${AGENT_CMD[@]}" >> "$LOG_FILE" 2>&1 &
    fi
    BGPID=$!
    echo "$BGPID" > "$PID_FILE"
    ok() { echo -e "${GREEN}[gru]${RESET} $*"; }
    ok "Gru daemon started (PID $BGPID)"
    ok "Attach with:  $0 attach"
    ok "Follow logs:  tail -f $LOG_FILE"
else
    exec "${AGENT_CMD[@]}"
fi
