#!/usr/bin/env bash
# minions/bin/viz — MinionsOS Observatory launcher (machine-singleton).
#
# Usage:
#   ./viz start [--port N] [--foreground]
#   ./viz stop
#   ./viz status
#   ./viz open
#   ./viz logs [--tail N] [--follow]
#   ./viz register
#   ./viz deregister
#   ./viz heartbeat
#   ./viz ensure
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    TARGET="$(readlink "$SOURCE")"
    if [[ "$TARGET" = /* ]]; then SOURCE="$TARGET"
    else SOURCE="$(cd "$(dirname "$SOURCE")" && pwd)/$TARGET"; fi
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Locate the MinionsOS root by walking up from SCRIPT_DIR looking for the
# `pyproject.toml` marker. This is robust whether the launcher is invoked as a
# symlink or as a copy at repo root.
ROOT="$SCRIPT_DIR"
while [ "$ROOT" != "/" ] && [ ! -f "$ROOT/pyproject.toml" ]; do
    ROOT="$(dirname "$ROOT")"
done
[ -f "$ROOT/pyproject.toml" ] || { echo "[viz] could not locate MinionsOS root from $SCRIPT_DIR" >&2; exit 1; }

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; RESET='\033[0m'
info()  { echo -e "${CYAN}[viz]${RESET} $*"; }
ok()    { echo -e "${GREEN}[viz]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[viz]${RESET} $*"; }
die()   { echo -e "${RED}[viz]${RESET} $*" >&2; exit 1; }

USER_DIR="$HOME/.minionsos"
REGISTRY="$USER_DIR/grus.json"
REG_LOCK="$USER_DIR/grus.lock"
VIZ_PID="$USER_DIR/viz.pid"
VIZ_PORT_FILE="$USER_DIR/viz.port"
VIZ_URL_FILE="$USER_DIR/viz.url"
VIZ_LOCK="$USER_DIR/viz.lock"
LOG_DIR="$ROOT/minions/state/logs"
LOG_FILE="$LOG_DIR/viz.log"
VIZ_DIR="$ROOT/minions-viz"
VIZ_BUILD_MARKER="$VIZ_DIR/dist/web/index.html"
mkdir -p "$LOG_DIR" "$USER_DIR"
chmod 0700 "$USER_DIR" 2>/dev/null || true

DEFAULT_PORT="${MINIONS_VIZ_PORT:-7891}"

usage() {
    cat <<EOF
./viz — MinionsOS Observatory control (machine-wide singleton)

Commands:
  start [--port N] [--foreground]   Start viz if not already running
  stop                              Stop viz (owner only)
  status                            Show running state + URL
  open                              Open dashboard in browser
  logs [--tail N] [--follow]        Tail/follow viz log
  register                          Register this Gru in ~/.minionsos/grus.json
  deregister                        Remove this Gru from registry
  heartbeat                         Refresh last_seen for this Gru
  ensure                            register + start (no-op if running)

Env:
  MINIONS_VIZ_PORT=N                Preferred port (default 7891; scans 7891..7910)
  MINIONS_GRU_LABEL=<name>          Override label on register
EOF
}

pid_alive() { local pid="$1"; [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; }
read_pid()  { [ -f "$VIZ_PID" ] && cat "$VIZ_PID" || true; }
read_port() { [ -f "$VIZ_PORT_FILE" ] && cat "$VIZ_PORT_FILE" || echo "$DEFAULT_PORT"; }

gru_id() {
    if command -v shasum &>/dev/null; then
        printf '%s' "$ROOT" | shasum -a 1 | awk '{print substr($1,1,12)}'
    else
        printf '%s' "$ROOT" | sha1sum | awk '{print substr($1,1,12)}'
    fi
}
parent_repo() { dirname "$ROOT"; }
gru_label() {
    if [ -n "${MINIONS_GRU_LABEL:-}" ]; then echo "$MINIONS_GRU_LABEL"; return; fi
    basename "$(parent_repo)"
}

http_probe() {
    local port="$1"
    curl -sfS --max-time 1 "http://127.0.0.1:${port}/health" >/dev/null 2>&1 \
        || curl -sfS --max-time 1 "http://127.0.0.1:${port}/" >/dev/null 2>&1
}

port_free() {
    local port="$1"
    if command -v python3 &>/dev/null; then
        python3 -c "
import socket,sys
s=socket.socket()
try: s.bind(('127.0.0.1',int(sys.argv[1]))); s.close(); sys.exit(0)
except OSError: sys.exit(1)
" "$port" 2>/dev/null
    else
        ! nc -z 127.0.0.1 "$port" 2>/dev/null
    fi
}

pick_port() {
    local preferred="${1:-$DEFAULT_PORT}"
    if port_free "$preferred"; then echo "$preferred"; return; fi
    local p
    for p in $(seq 7891 7910); do
        if port_free "$p"; then echo "$p"; return; fi
    done
    die "no free port in 7891..7910"
}

lock_acquire() {
    local lock="$1"; local timeout="${2:-5}"
    local i=0
    while ! mkdir "$lock" 2>/dev/null; do
        i=$((i+1))
        if [ $i -gt $((timeout*10)) ]; then
            if [ -d "$lock" ]; then
                local mtime now
                mtime=$(stat -f %m "$lock" 2>/dev/null || stat -c %Y "$lock" 2>/dev/null || echo 0)
                now=$(date +%s)
                if [ $((now - mtime)) -gt 30 ]; then rmdir "$lock" 2>/dev/null || true; continue; fi
            fi
            return 1
        fi
        sleep 0.1
    done
    return 0
}
lock_release() { rmdir "$1" 2>/dev/null || true; }

registry_upsert() {
    local id label root parent state_dir now
    id="$(gru_id)"; label="$(gru_label)"
    root="$ROOT"; parent="$(parent_repo)"; state_dir="$ROOT/minions/state"
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    lock_acquire "$REG_LOCK" 5 || die "could not acquire registry lock"
    python3 - "$REGISTRY" "$id" "$label" "$root" "$parent" "$state_dir" "$now" <<'PY'
import json, os, sys, tempfile
path, gid, label, root, parent, state_dir, now = sys.argv[1:]
try:
    with open(path) as f: data = json.load(f)
except Exception:
    data = {"grus": []}
grus = data.get("grus", [])
found = False
for g in grus:
    if g.get("id") == gid:
        g.update({"label": label, "root_path": root, "parent_repo": parent,
                  "state_dir": state_dir, "last_seen": now})
        g.setdefault("registered_at", now)
        found = True; break
if not found:
    grus.append({"id": gid, "label": label, "root_path": root,
                 "parent_repo": parent, "state_dir": state_dir,
                 "registered_at": now, "last_seen": now})
data["grus"] = grus
d = os.path.dirname(path) or "."
fd, tmp = tempfile.mkstemp(dir=d)
with os.fdopen(fd, "w") as f: json.dump(data, f, indent=2)
os.chmod(tmp, 0o600); os.replace(tmp, path)
PY
    lock_release "$REG_LOCK"
}

registry_touch() {
    local id now
    id="$(gru_id)"; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    lock_acquire "$REG_LOCK" 5 || return 1
    python3 - "$REGISTRY" "$id" "$now" <<'PY' 2>/dev/null || true
import json, os, sys, tempfile
path, gid, now = sys.argv[1:]
try:
    with open(path) as f: data = json.load(f)
except Exception:
    data = {"grus": []}
for g in data.get("grus", []):
    if g.get("id") == gid:
        g["last_seen"] = now; break
d = os.path.dirname(path) or "."
fd, tmp = tempfile.mkstemp(dir=d)
with os.fdopen(fd, "w") as f: json.dump(data, f, indent=2)
os.chmod(tmp, 0o600); os.replace(tmp, path)
PY
    lock_release "$REG_LOCK"
}

registry_remove() {
    local id; id="$(gru_id)"
    lock_acquire "$REG_LOCK" 5 || die "could not acquire registry lock"
    python3 - "$REGISTRY" "$id" <<'PY'
import json, os, sys, tempfile
path, gid = sys.argv[1:]
try:
    with open(path) as f: data = json.load(f)
except Exception:
    data = {"grus": []}
data["grus"] = [g for g in data.get("grus", []) if g.get("id") != gid]
d = os.path.dirname(path) or "."
fd, tmp = tempfile.mkstemp(dir=d)
with os.fdopen(fd, "w") as f: json.dump(data, f, indent=2)
os.chmod(tmp, 0o600); os.replace(tmp, path)
PY
    lock_release "$REG_LOCK"
}

ensure_build() {
    if [ -f "$VIZ_BUILD_MARKER" ]; then return 0; fi
    if ! command -v node &>/dev/null || ! command -v npm &>/dev/null; then
        die "minions-viz is not built and node/npm are missing."
    fi
    info "Building minions-viz (first-time)..."
    (
        cd "$VIZ_DIR"
        if [ -f package-lock.json ]; then
            install_cmd="ci"
        else
            install_cmd="install"
        fi
        NPM_CONFIG_AUDIT=false \
            NPM_CONFIG_FUND=false \
            NPM_CONFIG_PROGRESS=false \
            NPM_CONFIG_UPDATE_NOTIFIER=false \
            npm "$install_cmd" --loglevel=warn
        npm run build
    ) || die "minions-viz build failed."
    ok "minions-viz built."
}

stop_running() {
    local pid; pid="$(read_pid)"
    if [ -n "$pid" ] && pid_alive "$pid"; then
        local pid_user
        pid_user="$(ps -o user= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
        if [ -n "$pid_user" ] && [ "$pid_user" != "$(id -un)" ]; then
            warn "viz PID $pid belongs to $pid_user, not $(id -un); refusing to stop."
            return 1
        fi
        info "Stopping viz (PID $pid)..."
        local pgid
        pgid="$(ps -o pgid= "$pid" 2>/dev/null | tr -d ' ' || true)"
        [ -n "$pgid" ] && kill -TERM -- "-$pgid" 2>/dev/null || true
        kill -TERM "$pid" 2>/dev/null || true
        for _ in 1 2 3 4 5 6; do pid_alive "$pid" || break; sleep 0.5; done
        if pid_alive "$pid"; then
            kill -KILL "$pid" 2>/dev/null || true
            [ -n "$pgid" ] && kill -KILL -- "-$pgid" 2>/dev/null || true
        fi
        ok "Stopped."
    fi
    rm -f "$VIZ_PID" "$VIZ_PORT_FILE" "$VIZ_URL_FILE"
}

cmd_start() {
    local port="$DEFAULT_PORT"
    local foreground=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port) port="$2"; shift 2 ;;
            --foreground|-F) foreground=1; shift ;;
            *) die "Unknown arg to start: $1" ;;
        esac
    done

    lock_acquire "$VIZ_LOCK" 10 || die "could not acquire viz lock"
    trap 'lock_release "$VIZ_LOCK"' EXIT

    local existing_pid existing_port
    existing_pid="$(read_pid)"
    existing_port="$(read_port)"
    if [ -n "$existing_pid" ] && pid_alive "$existing_pid" && http_probe "$existing_port"; then
        ok "viz already running (PID $existing_pid) at http://127.0.0.1:${existing_port}"
        return 0
    fi
    rm -f "$VIZ_PID" "$VIZ_PORT_FILE" "$VIZ_URL_FILE"

    port="$(pick_port "$port")"
    ensure_build
    command -v node &>/dev/null || die "node not found on PATH."
    local tsx_preflight="./node_modules/tsx/dist/preflight.cjs"
    local tsx_loader_import="file://$VIZ_DIR/node_modules/tsx/dist/loader.mjs"
    [ -f "$VIZ_DIR/$tsx_preflight" ] || die "tsx runtime missing; run: cd minions-viz && npm install"
    [ -f "$VIZ_DIR/node_modules/tsx/dist/loader.mjs" ] || die "tsx runtime missing; run: cd minions-viz && npm install"

    info "Starting viz on port $port..."
    if [ "$foreground" = "1" ]; then
        cd "$VIZ_DIR"
        echo "$port" >"$VIZ_PORT_FILE"
        echo "http://127.0.0.1:${port}" >"$VIZ_URL_FILE"
        PORT="$port" MINIONS_ROOT="$ROOT" exec node --require "$tsx_preflight" --import "$tsx_loader_import" src/server/index.ts
    fi

    (
        cd "$VIZ_DIR"
        # Detach the Node process into its own process group so `./viz stop`
        # can `kill -- -$pgid` without collaterally killing the caller (e.g.
        # a parent pytest or shell). Prefer setsid (Linux); fall back to a
        # tiny python shim that calls os.setsid() on macOS, where setsid(1)
        # is not shipped.
        if command -v setsid >/dev/null 2>&1; then
            PORT="$port" MINIONS_ROOT="$ROOT" nohup setsid node --require "$tsx_preflight" --import "$tsx_loader_import" src/server/index.ts >>"$LOG_FILE" 2>&1 &
        elif command -v python3 >/dev/null 2>&1; then
            PORT="$port" MINIONS_ROOT="$ROOT" nohup python3 -c \
                'import os,sys; os.setsid(); os.execvp(sys.argv[1], sys.argv[1:])' \
                node --require "$tsx_preflight" --import "$tsx_loader_import" src/server/index.ts >>"$LOG_FILE" 2>&1 &
        else
            PORT="$port" MINIONS_ROOT="$ROOT" nohup node --require "$tsx_preflight" --import "$tsx_loader_import" src/server/index.ts >>"$LOG_FILE" 2>&1 &
        fi
        echo $! >"$VIZ_PID"
    )
    echo "$port" >"$VIZ_PORT_FILE"
    echo "http://127.0.0.1:${port}" >"$VIZ_URL_FILE"

    local up=0
    for _ in $(seq 1 16); do
        if http_probe "$port"; then up=1; break; fi
        sleep 0.5
    done
    local pid; pid="$(read_pid)"
    if [ "$up" = "1" ]; then
        ok "viz running (PID $pid) at http://127.0.0.1:${port}"
    else
        warn "viz started (PID $pid) but did not respond within 8s. See: $LOG_FILE"
    fi
}

cmd_stop() { stop_running; }

cmd_status() {
    local pid port
    pid="$(read_pid)"; port="$(read_port)"
    if [ -n "$pid" ] && pid_alive "$pid"; then
        local probe="unreachable"
        http_probe "$port" && probe="reachable"
        echo -e "${GREEN}running${RESET}  PID=$pid  port=$port  $probe  URL=http://127.0.0.1:${port}"
    else
        echo -e "${YELLOW}stopped${RESET}  (last port=${port})"
        return 1
    fi
}

cmd_open() {
    local port; port="$(read_port)"
    local url="http://127.0.0.1:${port}"
    if command -v open &>/dev/null; then open "$url"
    elif command -v xdg-open &>/dev/null; then xdg-open "$url" >/dev/null 2>&1 &
    else warn "No 'open'/'xdg-open'. Visit: $url"
    fi
}

cmd_logs() {
    local tail_n=50 follow=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tail|-n) tail_n="$2"; shift 2 ;;
            --follow|-f) follow=1; shift ;;
            *) die "Unknown arg to logs: $1" ;;
        esac
    done
    [ -f "$LOG_FILE" ] || die "No log file yet: $LOG_FILE"
    if [ "$follow" = "1" ]; then tail -n "$tail_n" -f "$LOG_FILE"
    else tail -n "$tail_n" "$LOG_FILE"; fi
}

cmd_register()   { registry_upsert; ok "registered Gru $(gru_id) [$(gru_label)]"; }
cmd_deregister() { registry_remove; ok "deregistered Gru $(gru_id)"; }
cmd_heartbeat()  { registry_touch || true; }
cmd_ensure()     { registry_upsert; cmd_start; }

SUBCMD="${1:-}"
case "$SUBCMD" in
    start) shift; cmd_start "$@" ;;
    stop) shift; cmd_stop "$@" ;;
    status) shift; cmd_status "$@" ;;
    open) shift; cmd_open "$@" ;;
    logs) shift; cmd_logs "$@" ;;
    register) shift; cmd_register "$@" ;;
    deregister) shift; cmd_deregister "$@" ;;
    heartbeat) shift; cmd_heartbeat "$@" ;;
    ensure) shift; cmd_ensure "$@" ;;
    ""|--help|-h|help) usage ;;
    *) die "Unknown command: $SUBCMD (try --help)" ;;
esac
