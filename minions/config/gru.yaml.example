# Gru supervisor configuration.
# Copy this file to gru.yaml and adjust as needed.
# gru.yaml is gitignored; only gru.yaml.example is committed.

# How often Gru emits a heartbeat status report.
# Format: "<N>h" or "<N>m". Set to "0" to disable.
heartbeat_report_interval: "3m"

# Whether Gru (and all roles it spawns) may use web search tools.
# Set to false to air-gap the session.
allow_web_search: true

# Logging verbosity: debug | info | warning | error
log_level: info

# Optional path to the author's source git repo. Used as the *seed* for new
# per-project bare repos at project_create time: the author's current HEAD
# (minus MinionsOS/ itself and files larger than 500 MB) is imported into
# project_<port>/parent_repo.git/ and committed once. After seeding, the
# author repo is never touched again — project worktrees branch off the
# per-project bare repo, so author-side `.git` stays untouched.
# Defaults to the directory containing MinionsOS (typically the user's
# working repo). Set this when MinionsOS sits somewhere unrelated to the
# code you want to research over.
author_repo:

# Optional directory that contains project_<port>/ runtime trees.
# Defaults to the directory containing MinionsOS.
projects_root:

# Noter periodic wake cadence. Noter wakes every interval to flush the buffered
# Draft (L1) to a single commit on the shared branch
# (mos_draft_commit_shared), and to consider whether a fresh staged report
# is due. Draft flushes happen on every periodic wake; reports are
# throttled by noter_report_interval below.
noter_periodic_interval: 3m

# Target cadence for Noter staged report publishes. Noter only publishes a new
# report once this much time has elapsed since the last one (checked on each
# periodic wake). Set to "0" to disable scheduled reports.
noter_report_interval: 30m

# Minimum local EACN credit balance to keep available for Gru and registered
# Role agents. Project-local tasks still default to budget=0; this is a safety
# margin for explicit nonzero-budget experiments.
local_eacn_initial_balance: 10000

# Optional `owner/repo` target for `mos_issue_report` GitHub uploads. When
# set, every issue Roles file via `mos_issue_report` is also posted via
# `gh issue create` (best-effort — local JSONL stays the source of truth,
# upload failures are logged but never block the local write). Requires the
# `gh` CLI to be authenticated for this user. Override per process with
# MINIONS_GITHUB_ISSUES_REPO. Leave unset to keep issues local only.
# github_issues_repo: Minions-Land/MinionsOS

# Structured backend/role health events are always written to
# project_<port>/logs/health_events.jsonl. Set this true to also post those
# events to project-local Gru and Noter over EACN.
health_event_eacn_notifications: false

# Minimum seconds between any two dispatches for the same role.
role_cooldown_seconds: 30

# Python-side experiment queue reconcile cadence. This keeps queued experiment
# units flowing onto newly-free GPUs without waking Coder just to schedule.
experiment_reconcile_interval_seconds: 30

# Wall-clock seconds of silence after which mos_await_events returns a stable
# synthetic keepalive event so the Role's long-lived claude process re-touches
# its prompt cache before the TTL cliff. As of v15.20.1, every Role is launched
# with ENABLE_PROMPT_CACHING_1H=1 (see role_launcher.py) which lifts the cliff
# to ~3600s on backends that honor it. Default 3000s (50 min) leaves a 10-min
# safety margin against the 1h cliff and cuts the previous 240s default's
# keepalive frequency by ~12x. On third-party gateways that strip the 1h flag
# and silently fall back to 5-min TTL, set this back to 240 here. Each
# keepalive costs ~$0.006; missing the cliff costs ~$0.098 (16x penalty).
# Set to 0 to disable for backends with longer or unbounded TTL.
cache_keepalive_seconds: 3000

# EACN agent_id used when system components (e.g. the Python-side wakeup
# dispatcher posting context-veto warnings) address Gru. Change only if
# you have renamed the Gru agent on the EACN bus.
gru_eacn_agent_id: gru

# Agent host. Claude Code is the default for Gru and Role wakeups. Set to
# "codex" to launch through Codex instead. You can also override per process
# with MINIONS_AGENT_HOST.
agent_host: claude

# Model for the Noter role. As of v15.19.1, all roles default to Opus for
# cross-role consistency — Sonnet's self-tangling on long Draft / Book
# curation sessions outweighed the per-token cost gap. Override to "sonnet"
# only on short-leaf Noter projects where curation dominates and reasoning
# depth doesn't matter. Accepts any model alias or full name that the
# claude CLI understands.
noter_model: opus

# Optional Codex model. Leave null to use the Codex CLI profile/default.
codex_model:
codex_reasoning_effort: xhigh
# MinionsOS launches Codex non-interactively. Bypass keeps role wakeups fully
# automated and avoids platform sandbox/bwrap failures on machines where Codex's
# local sandbox cannot initialize.
codex_bypass_approvals_and_sandbox: true
codex_sandbox: danger-full-access  # used only when bypass is disabled
codex_approval_policy: never

# Context-window size thresholds, expressed as a fraction of the model context
# window so they auto-scale as we upgrade to larger-context models.
# Rationale: Context Rot / NoLiMa research shows effective context degrades
# well before the nominal window is full — keep transcript usage well under it.
# Defaults (1M-token window): soft=100k, hard=150k, veto=200k tokens.
# These are unrelated to the on-disk L1 Draft
# (branches/shared/draft/draft.json).
#
# NOTE (2026-05-20): these thresholds are RESERVED for a future programmatic
# compaction-gating path. Today, role agents decide when to call
# mos_compact_context based on self-judgment; nothing in the runtime reads
# these values. Tuning them here will not change behavior until the wiring
# lands. See dev-log/2026-05.md "context_*_pct thresholds: dead config".
model_context_window_tokens: 1000000
context_soft_pct: 0.10   # gentle compression hint
context_hard_pct: 0.15   # require compression before new events
context_veto_pct: 0.20   # block normal work, try maintenance compaction, alert Gru


# Evidence-gated Role evolution. Three primitives:
#   - SPLIT:   one Role becomes >=2 specialists when artifact-grounded
#              failures partition into distinct sub-domains.
#   - MERGE:   two active Roles fuse into one when their behaviour has
#              converged (artifact-overlap >= threshold). Roles need NOT
#              share a SPLIT lineage.
#   - DISMISS: a Role with no recent work is retired. Distinct from
#              MERGE because a starved Role should not be fused into
#              another Role's scope — it should stop existing. If new
#              work needs that scope later, a separate spawn trigger
#              handles it.
#
# Default is recommend-only — Gru writes recommendations to
# branches/shared/governance/role_evolution.jsonl every interval, but
# does NOT actually spawn / merge / dismiss anything until
# role_evolution_auto_apply is set true. Turn on auto_apply only after the
# recommendation stream has been validated on a real workload; the
# experimental pilot under experiments/expert_split_merge/ shows split can
# hurt accuracy when the trigger fires too eagerly.
role_evolution_interval_seconds: 900     # 15 min between evaluation passes
role_evolution_auto_apply: false         # recommend-only by default

# Per-trigger thresholds. Override individually under the
# `role_evolution:` key when needed.
# role_evolution:
#   split_min_failures: 5
#   split_min_subdomains: 2
#   split_min_per_subdomain: 3
#   split_recent_window_hours: 24
#   dismiss_starve_min_age_hours: 6
#   dismiss_starve_max_tasks: 1
#   merge_convergence_threshold: 0.75
#   cooldown_after_split_hours: 12
#   cooldown_after_merge_hours: 6
#   cooldown_after_dismiss_hours: 6
